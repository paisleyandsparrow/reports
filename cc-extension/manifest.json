{
  "manifest_version": 3,
  "name": "Paisley & Sparrow — CC Session Capture",
  "version": "1.0.0",
  "description": "Capture your Amazon Creator Connections session for automated campaign management.",

  "permissions": [
    "cookies",
    "identity",
    "storage"
  ],
  "host_permissions": [
    "https://*.amazon.com/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "oauth2": {
    "client_id": "947857596841-f8juc9da0eks3hr6uftbeededudbmrac.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  }
}
