---
---
<footer>
  <div class="foot-inner">
    <div class="foot-brand">
      <a href="/" class="wordmark" style="font-size:20px;" aria-label="Creator Coders">creator coders</a>
      <span class="foot-meta">© 2026 Creator Coders. Software for serious creators.</span>
    </div>
    <div class="foot-right">
      <nav class="foot-links">
        <a href="/contact">Contact</a>
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
      </nav>
      <div class="foot-social">
        <!-- Instagram -->
        <a href="https://www.instagram.com/creatorcodersportal" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4.5"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <!-- X / Twitter -->
        <a href="https://x.com/CreatorCoders" target="_blank" rel="noopener noreferrer" aria-label="X">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <!-- YouTube -->
        <a href="https://www.youtube.com/@CreatorCoders" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--cream-line);
    padding: 48px 32px;
    background: var(--cream);
  }
  .foot-inner {
    max-width: 1200px; margin: 0 auto;
    display: flex; justify-content: space-between;
    align-items: center; flex-wrap: wrap; gap: 16px;
  }
  .foot-brand { display: flex; align-items: center; gap: 16px; }
  .foot-meta { font-size: 13px; color: var(--muted); letter-spacing: 0.02em; }
  .foot-right { display: flex; flex-direction: column; align-items: flex-end; gap: 14px; }
  .foot-links { display: flex; gap: 28px; font-size: 13px; }
  .foot-links a { color: var(--muted); text-decoration: none; transition: color 0.18s ease; }
  .foot-links a:hover { color: var(--pink); }
  .foot-social { display: flex; gap: 18px; align-items: center; }
  .foot-social a { color: var(--muted); text-decoration: none; transition: color 0.18s ease; display: flex; align-items: center; }
  .foot-social a:hover { color: var(--pink); }
</style>
