---
---
<section class="block" id="pricing">
  <div class="price-block">
    <div class="price-eyebrow">Try Creator Coders</div>
    <h3 class="price-headline">7 days free.<br/><em>Then $100/month.</em></h3>
    <p class="price-sub">
      No card required to start. Cancel anytime, and keep the reports we've already pulled.
    </p>
    <a class="btn-primary price-cta" href="https://portal.creatorcoders.com/login">
      <svg class="google-icon" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z" fill="#4285F4"/>
        <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853"/>
        <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
        <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
      </svg>
      Continue with Google — start free trial
    </a>
    <div class="price-fineprint">Sign up takes 10 seconds with your Google account. No card required.</div>
    <div class="price-signin">Already have an account? <a href="https://portal.creatorcoders.com/login">Sign in →</a></div>
  </div>
</section>

<style>
  .block { max-width: 1200px; margin: 0 auto; padding: 120px 32px; }
  .price-block {
    border: 1px solid var(--cream-line);
    border-radius: 24px; padding: 64px;
    text-align: center;
    background: #fff;
    max-width: 720px; margin: 0 auto;
    position: relative; overflow: hidden;
    box-shadow: 0 30px 80px rgba(26,20,16,0.06);
  }
  .price-block::before {
    content: '';
    position: absolute; top: -120px; left: 50%;
    transform: translateX(-50%);
    width: 360px; height: 360px;
    background: radial-gradient(circle, rgba(236,72,153,0.14) 0%, transparent 70%);
    pointer-events: none;
  }
  .price-eyebrow {
    font-size: 11px; letter-spacing: 0.4em;
    text-transform: uppercase; color: var(--pink);
    margin-bottom: 24px; position: relative;
  }
  .price-headline {
    font-family: Georgia, 'Times New Roman', serif;
    font-weight: 400; font-size: 56px; line-height: 1;
    color: var(--espresso); margin-bottom: 16px;
    letter-spacing: -0.02em; position: relative;
  }
  .price-headline em { font-style: italic; color: var(--pink); }
  .price-sub {
    font-size: 16px; line-height: 1.6;
    color: var(--muted); margin-bottom: 36px; position: relative;
  }
  .price-cta {
    display: inline-flex; align-items: center; gap: 10px;
    margin: 0 auto 16px; position: relative;
  }
  .google-icon { width: 18px; height: 18px; flex-shrink: 0; }
  .price-fineprint {
    font-size: 12px; color: var(--muted); letter-spacing: 0.04em; position: relative;
  }
  .price-signin {
    margin-top: 14px; font-size: 13px; color: var(--muted); position: relative;
  }
  .price-signin a {
    color: var(--pink); text-decoration: none; font-weight: 500;
  }
  .price-signin a:hover { text-decoration: underline; }
  @media (max-width: 900px) {
    .block { padding: 80px 24px; }
    .price-block { padding: 48px 28px; }
    .price-cta { width: 100%; justify-content: center; }
  }
</style>
